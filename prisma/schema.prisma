datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

model Post {
  id         String   @id @default(cuid())
  authorId   String   @db.VarChar(36)
  body       String   @db.Text
  media      Json?
  visibility String   @default("public")
  repostOfId String?
  status     PostStatus @default(ACTIVE)
  hiddenAt   DateTime?
  hiddenReason PostHiddenReason?
  createdAt  DateTime @default(now())

  repostOf Post? @relation("PostReposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts Post[] @relation("PostReposts")
  likes Like[]
  comments Comment[]

  @@index([createdAt, id])
  @@index([status, createdAt, id])
  @@index([authorId, status, createdAt, id])
  @@index([repostOfId, status, createdAt, id])
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String   @db.VarChar(36)
  body      String   @db.Text
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt, id])
  @@index([authorId, createdAt, id])
}

model HomeFeed {
  ownerId    String
  postId     String
  rank       Int      @default(0)
  insertedAt DateTime @default(now())

  @@id([ownerId, postId])
  @@index([ownerId, insertedAt, postId])
}

model InboxEvent {
  id            String   @id @default(cuid())
  consumerGroup String
  topic         String
  partition     Int?
  offset        String?
  eventId       String?
  eventKey      String
  status        String   @default("PROCESSING")
  receivedAt    DateTime @default(now())
  processedAt   DateTime?
  lastError     String?
  updatedAt     DateTime @updatedAt

  @@unique([consumerGroup, eventKey])
  @@index([consumerGroup, status])
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
  DEAD_LETTER
}

model OutboxEvent {
  id            String   @id
  topic         String
  eventKey      String?
  payload       Json
  status        OutboxEventStatus @default(PENDING)
  attempts      Int      @default(0)
  nextAttemptAt DateTime @default(now())
  lastError     String?
  publishedAt   DateTime?
  deadLetteredAt DateTime?
  deadLetterTopic String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, nextAttemptAt, createdAt])
  @@index([createdAt])
}

enum PostStatus {
  ACTIVE
  HIDDEN
}

enum PostHiddenReason {
  ADMIN_HIDDEN
  USER_DEACTIVATED
}
