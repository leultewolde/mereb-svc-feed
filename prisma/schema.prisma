datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

model Post {
  id         String   @id @default(cuid())
  authorId   String   @db.VarChar(36)
  body       String   @db.Text
  media      Json?
  visibility String   @default("public")
  createdAt  DateTime @default(now())

  likes Like[]

  @@index([createdAt, id])
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId, createdAt])
}

model HomeFeed {
  ownerId    String
  postId     String
  rank       Int      @default(0)
  insertedAt DateTime @default(now())

  @@id([ownerId, postId])
  @@index([ownerId, insertedAt, postId])
}

model InboxEvent {
  id            String   @id @default(cuid())
  consumerGroup String
  topic         String
  partition     Int?
  offset        String?
  eventId       String?
  eventKey      String
  status        String   @default("PROCESSING")
  receivedAt    DateTime @default(now())
  processedAt   DateTime?
  lastError     String?
  updatedAt     DateTime @updatedAt

  @@unique([consumerGroup, eventKey])
  @@index([consumerGroup, status])
}

model OutboxEvent {
  id            String   @id
  topic         String
  eventKey      String?
  payload       Json
  status        String   @default("PENDING")
  attempts      Int      @default(0)
  nextAttemptAt DateTime @default(now())
  lastError     String?
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, nextAttemptAt, createdAt])
  @@index([createdAt])
}
